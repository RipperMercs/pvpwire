{
  "name": "pvpwire",
  "version": "1.0.0",
  "private": true,
  "description": "The hub for competitive PvP and esports.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "scan-emdash": "node scripts/scan-emdash.mjs",
    "scan-secrets": "node scripts/scan-secrets.mjs",
    "prepare": "husky",
    "worker:dev": "cd worker && wrangler dev",
    "worker:deploy": "cd worker && wrangler deploy",
    "fetch-feeds": "tsx scripts/fetch-feeds.ts",
    "build-search-index": "tsx scripts/build-search-index.ts",
    "build-rss": "tsx scripts/build-rss.ts",
    "build-tournaments-json": "tsx scripts/build-tournaments-json.ts",
    "build-steam-app-ids": "tsx scripts/build-steam-app-ids.ts",
    "build-pandascore-ids": "tsx scripts/build-pandascore-ids.ts",
    "build-live-catalog": "tsx scripts/build-live-catalog.ts",
    "fetch-org-logos": "node scripts/fetch-org-logos.mjs",
    "fetch-game-screenshots": "node scripts/fetch-game-screenshots.mjs",
    "backfill-steam-app-ids": "node scripts/backfill-steam-app-ids.mjs",
    "validate-schema": "node scripts/validate-schema.mjs",
    "audit-links": "node scripts/audit-links.mjs",
    "audit-urls": "node scripts/audit-urls.mjs",
    "audit-meta": "node scripts/audit-meta.mjs",
    "audit-headings": "node scripts/audit-headings.mjs",
    "audit-seo": "npm run validate-schema && npm run audit-links && npm run audit-urls && npm run audit-meta && npm run audit-headings",
    "prebuild": "tsx scripts/build-search-index.ts && tsx scripts/build-rss.ts && tsx scripts/build-tournaments-json.ts && tsx scripts/build-steam-app-ids.ts && tsx scripts/build-pandascore-ids.ts && tsx scripts/build-live-catalog.ts"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "fuse.js": "^7.0.0",
    "gray-matter": "^4.0.3",
    "next": "14.2.35",
    "next-mdx-remote": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "husky": "^9.0.11",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
